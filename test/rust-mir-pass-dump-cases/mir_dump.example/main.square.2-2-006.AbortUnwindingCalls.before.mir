// MIR for `square` before AbortUnwindingCalls

fn square(_1: i32) -> i32 {
    debug num => _1;
    let mut _0: i32;
    let mut _2: i32;
    let mut _3: i32;
    let mut _4: (i32, bool);

    bb0: {
        StorageLive(_2);
        _2 = copy _1;
        StorageLive(_3);
        _3 = copy _1;
        _4 = MulWithOverflow(copy _2, copy _3);
        assert(!move (_4.1: bool), "attempt to compute `{} * {}`, which would overflow", move _2, move _3) -> [success: bb1, unwind continue];
    }

    bb1: {
        _0 = move (_4.0: i32);
        StorageDead(_3);
        StorageDead(_2);
        return;
    }
}
