{
  "compilerOptions": {
    /* Code generation */
    "sourceMap": true,
    "ignoreDeprecations": "6.0",
    "importHelpers": true,
    /* Module resolution */
    "esModuleInterop": true,
    /* Other options */
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "strict": true,
    "noImplicitAny": false,
    "noImplicitOverride": true,
    "strictNullChecks": true,
    "strictFunctionTypes": true,
    "noUnusedLocals": true,
    "noImplicitThis": true
  }
}
